@model IEnumerable<TimeEntry>
@{
    ViewData["Title"] = "Time Entries";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Time Entries</h1>
    <a class="btn btn-primary" asp-action="Create">Log Time</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead><tr><th>Date</th><th>Task</th><th>Project</th><th>Resource</th><th>Hours</th><th>Description</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var entry in Model)
            {
                <tr>
                    <td>@entry.Date.ToShortDateString()</td>
                    <td>@entry.ProjectTask?.Title</td>
                    <td>@entry.ProjectTask?.Project?.Name</td>
                    <td>@entry.Resource?.FullName</td>
                    <td>@entry.Hours</td>
                    <td>@entry.Description</td>
                    <td class="table-actions">
                        <a asp-action="Edit" asp-route-id="@entry.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@entry.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>