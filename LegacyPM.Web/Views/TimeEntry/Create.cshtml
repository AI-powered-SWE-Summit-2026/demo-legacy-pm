@model TimeEntry
@{
    ViewData["Title"] = "Create Time Entry";
}

<h1>Log Time Entry</h1>
<form asp-action="Create" method="post">
    <div class="form-row">
        <div class="form-group col-md-6"><label asp-for="ProjectTaskId"></label><select asp-for="ProjectTaskId" asp-items="ViewBag.Tasks" class="form-control"></select></div>
        <div class="form-group col-md-6"><label asp-for="ResourceId"></label><select asp-for="ResourceId" asp-items="ViewBag.Resources" class="form-control"></select></div>
    </div>
    <div class="form-row">
        <div class="form-group col-md-6"><label asp-for="Date"></label><input asp-for="Date" type="date" class="form-control" /></div>
        <div class="form-group col-md-6"><label asp-for="Hours"></label><input asp-for="Hours" class="form-control" /></div>
    </div>
    <div class="form-group"><label asp-for="Description"></label><textarea asp-for="Description" class="form-control"></textarea></div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>