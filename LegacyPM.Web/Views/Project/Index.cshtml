@model IEnumerable<Project>
@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Projects</h1>
    <a class="btn btn-primary" asp-action="Create">Create Project</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Owner</th>
            <th>Budget</th>
            <th>Updated</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var project in Model)
    {
        <tr>
            <td>@project.Name</td>
            <td>@project.Status</td>
            <td>@project.OwnerId</td>
            <td>@project.Budget.ToString("C")</td>
            <td>@project.UpdatedAt.ToString("g")</td>
            <td class="text-nowrap">
                <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@project.Id">Details</a>
                <a class="btn btn-sm btn-secondary" asp-action="Edit" asp-route-id="@project.Id">Edit</a>
                <form asp-action="Delete" asp-route-id="@project.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>