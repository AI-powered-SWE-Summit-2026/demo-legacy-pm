@model IEnumerable<ProjectTask>
@{
    ViewData["Title"] = "Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Tasks</h1>
    <a class="btn btn-primary" asp-action="Create">Create Task</a>
</div>

<form method="get" class="form-inline mb-3">
    <select name="projectId" asp-items="ViewBag.Projects" class="form-control mr-2">
        <option value="">All Projects</option>
    </select>
    <button type="submit" class="btn btn-secondary">Filter</button>
</form>

<table class="table table-striped">
    <thead><tr><th>Title</th><th>Project</th><th>Assigned To</th><th>Priority</th><th>Status</th><th>Due Date</th><th></th></tr></thead>
    <tbody>
    @foreach (var task in Model)
    {
        <tr>
            <td>@task.Title</td>
            <td>@task.Project?.Name</td>
            <td>@task.AssignedTo?.FullName</td>
            <td>@task.Priority</td>
            <td>@task.Status</td>
            <td>@task.DueDate.ToShortDateString()</td>
            <td><a class="btn btn-sm btn-secondary" asp-action="Edit" asp-route-id="@task.Id">Edit</a></td>
        </tr>
    }
    </tbody>
</table>