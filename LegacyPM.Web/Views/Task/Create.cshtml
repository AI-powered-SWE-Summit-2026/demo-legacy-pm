@model ProjectTask
@{
    ViewData["Title"] = "Create Task";
}

<h1>Create Task</h1>
<form asp-action="Create" method="post">
    <div class="form-row">
        <div class="form-group col-md-6"><label asp-for="Title"></label><input asp-for="Title" class="form-control" /></div>
        <div class="form-group col-md-6"><label asp-for="ProjectId"></label><select asp-for="ProjectId" asp-items="ViewBag.Projects" class="form-control"></select></div>
    </div>
    <div class="form-group"><label asp-for="Description"></label><textarea asp-for="Description" class="form-control"></textarea></div>
    <div class="form-row">
        <div class="form-group col-md-3"><label asp-for="AssignedToId"></label><select asp-for="AssignedToId" asp-items="ViewBag.Resources" class="form-control"><option value="">Unassigned</option></select></div>
        <div class="form-group col-md-3"><label asp-for="DueDate"></label><input asp-for="DueDate" type="date" class="form-control" /></div>
        <div class="form-group col-md-3"><label asp-for="Priority"></label><select asp-for="Priority" asp-items="Html.GetEnumSelectList<Priority>()" class="form-control"></select></div>
        <div class="form-group col-md-3"><label asp-for="Status"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<ProjectTaskStatus>()" class="form-control"></select></div>
    </div>
    <div class="form-row">
        <div class="form-group col-md-6"><label asp-for="EstimatedHours"></label><input asp-for="EstimatedHours" class="form-control" /></div>
        <div class="form-group col-md-6"><label asp-for="ActualHours"></label><input asp-for="ActualHours" class="form-control" /></div>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>