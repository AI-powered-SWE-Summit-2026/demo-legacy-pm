<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LegacyPM</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.6.2/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">LegacyPM</a>
        <div class="navbar-nav">
            <a class="nav-item nav-link" asp-controller="Project" asp-action="Index">Projects</a>
            <a class="nav-item nav-link" asp-controller="Task" asp-action="Index">Tasks</a>
            <a class="nav-item nav-link" asp-controller="Milestone" asp-action="Index">Milestones</a>
            <a class="nav-item nav-link" asp-controller="Resource" asp-action="Index">Resources</a>
            <a class="nav-item nav-link" asp-controller="TimeEntry" asp-action="Index">Time Entries</a>
            <a class="nav-item nav-link" asp-controller="Report" asp-action="Index">Reports</a>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>