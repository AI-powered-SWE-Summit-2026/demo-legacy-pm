@model IEnumerable<Resource>
@{
    ViewData["Title"] = "Resources";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Resources</h1>
    <a class="btn btn-primary" asp-action="Create">Add Resource</a>
</div>

<table class="table table-bordered">
    <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Department</th><th>Rate</th><th>Active</th></tr></thead>
    <tbody>
    @foreach (var resource in Model)
    {
        <tr>
            <td>@resource.FullName</td>
            <td>@resource.Email</td>
            <td>@resource.Role</td>
            <td>@resource.Department</td>
            <td>@resource.HourlyRate.ToString("C")</td>
            <td>@resource.IsActive</td>
        </tr>
    }
    </tbody>
</table>