@model IEnumerable<Resource>
@{
    ViewData["Title"] = "Resources";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Resources</h1>
    <a class="btn btn-primary" asp-action="Create">Add Resource</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Department</th><th>Rate</th><th>Active</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var resource in Model)
            {
                <tr>
                    <td>@resource.FullName</td>
                    <td>@resource.Email</td>
                    <td>@resource.Role</td>
                    <td>@resource.Department</td>
                    <td>@resource.HourlyRate.ToString("C")</td>
                    <td>@resource.IsActive</td>
                    <td class="table-actions">
                        <a asp-action="Edit" asp-route-id="@resource.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@resource.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Retire/Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>