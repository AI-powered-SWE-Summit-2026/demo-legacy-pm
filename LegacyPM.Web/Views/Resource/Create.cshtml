@model Resource
@{
    ViewData["Title"] = "Create Resource";
}

<h1>Create Resource</h1>
<form asp-action="Create" method="post">
    <div class="form-row">
        <div class="form-group col-md-6"><label asp-for="FullName"></label><input asp-for="FullName" class="form-control" /></div>
        <div class="form-group col-md-6"><label asp-for="Email"></label><input asp-for="Email" class="form-control" /></div>
    </div>
    <div class="form-row">
        <div class="form-group col-md-4"><label asp-for="Role"></label><input asp-for="Role" class="form-control" /></div>
        <div class="form-group col-md-4"><label asp-for="Department"></label><input asp-for="Department" class="form-control" /></div>
        <div class="form-group col-md-4"><label asp-for="HourlyRate"></label><input asp-for="HourlyRate" class="form-control" /></div>
    </div>
    <div class="form-check mb-3"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>