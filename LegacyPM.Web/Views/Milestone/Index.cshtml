@model IEnumerable<Milestone>
@{
    ViewData["Title"] = "Milestones";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Milestones</h1>
    <a class="btn btn-primary" asp-action="Create">Create Milestone</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead><tr><th>Name</th><th>Project</th><th>Due Date</th><th>Completed</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var milestone in Model)
            {
                <tr>
                    <td>@milestone.Name</td>
                    <td>@milestone.Project?.Name</td>
                    <td>@milestone.DueDate.ToShortDateString()</td>
                    <td>@(milestone.IsCompleted ? "Yes" : "No")</td>
                    <td class="table-actions">
                        <a asp-action="Edit" asp-route-id="@milestone.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@milestone.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>