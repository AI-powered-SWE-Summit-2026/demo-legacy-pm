@model LegacyPM.Web.Models.DashboardViewModel
@inject Microsoft.AspNetCore.Mvc.Rendering.IJsonHelper Json
@using System.Linq
@{
    ViewData["Title"] = "Dashboard";
    var milestones = ViewBag.UpcomingMilestones as IEnumerable<Milestone>;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">LegacyPM Dashboard</h1>
    <span class="text-muted">@DateTime.Now.ToString("dd/MM/yyyy")</span>
</div>

<div class="row mb-4">
    <div class="col-md-3"><div class="card"><div class="card-body"><h5>Total Projects</h5><div class="display-4">@Model.TotalProjects</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h5>Active Projects</h5><div class="display-4">@Model.ActiveProjects</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h5>Open Tasks</h5><div class="display-4">@Model.OpenTasks</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h5>Active Resources</h5><div class="display-4">@Model.ActiveResources</div></div></div></div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">Recent Projects</div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead><tr><th>Name</th><th>Status</th><th>Budget</th><th>End Date</th></tr></thead>
                    <tbody>
                    @foreach (var project in Model.RecentProjects)
                    {
                        <tr>
                            <td><a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id">@project.Name</a></td>
                            <td>@project.Status</td>
                            <td>@project.Budget.ToString("C")</td>
                            <td>@project.EndDate.ToShortDateString()</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">Upcoming Milestones</div>
            <ul class="list-group list-group-flush">
                @if (milestones != null)
                {
                    foreach (var milestone in milestones)
                    {
                        <li class="list-group-item">
                            <strong>@milestone.Name</strong><br />
                            <span class="text-muted">@milestone.Project?.Name - @milestone.DueDate.ToShortDateString()</span>
                        </li>
                    }
                }
            </ul>
        </div>
        <div class="alert alert-info">@Model.ExternalStatus</div>
    </div>
</div>

<script>
    window.dashboardModel = @Html.Raw(Json.Serialize(new
    {
        Model.TotalProjects,
        Model.ActiveProjects,
        Model.OpenTasks,
        Model.ActiveResources,
        Model.GeneratedAt,
        Model.ExternalStatus,
        RecentProjects = Model.RecentProjects.Select(project => new
        {
            project.Id,
            project.Name,
            Status = project.Status.ToString(),
            project.Budget,
            project.EndDate
        })
    }));
</script>