@model LegacyPM.Web.Models.ReportGenerateViewModel
@{
    ViewData["Title"] = "Generate Report";
}

<h1>Generate Report</h1>
<form asp-action="Generate" method="post">
    <div class="form-row">
        <div class="form-group col-md-6"><label asp-for="ProjectId"></label><select asp-for="ProjectId" asp-items="ViewBag.Projects" class="form-control"></select></div>
        <div class="form-group col-md-6"><label asp-for="ReportType"></label><input asp-for="ReportType" class="form-control" /></div>
    </div>
    <div class="form-group"><label asp-for="Parameters"></label><textarea asp-for="Parameters" class="form-control"></textarea></div>
    <button type="submit" class="btn btn-primary">Generate</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.GeneratedJson))
{
    <div class="card mt-4">
        <div class="card-header">Generated Output</div>
        <div class="card-body">
            <pre>@Model.GeneratedJson</pre>
        </div>
    </div>
}